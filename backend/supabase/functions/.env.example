# Supabase Edge Functions secrets for donation payments
# Copy values to Supabase secrets using:
# supabase secrets set --env-file backend/supabase/functions/.env

# Required for both web checkout and mobile payment sheet
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Required if recurring monthly donations are enabled in web checkout mode
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id_here

# Optional (recommended) for webhook-based reconciliation
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Existing project secrets likely already set in your environment
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Email / OTP (send-otp edge function) ──────────────────────────────────
# Primary: SMTP (e.g. Gmail, SendGrid, Brevo, Mailgun SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=your-app-password-here
EMAIL_FROM_NAME=ElderConnect+
# Optional: override the From address (defaults to EMAIL_USER)
EMAIL_FROM=noreply@yourdomain.com

# Fallback: Resend API (used if SMTP not configured or SMTP fails)
RESEND_API_KEY=re_your_resend_key

# Required for postcode/address lookup via OS Places (used by web + mobile)
OS_PLACES_API_KEY=your_os_places_api_key
OS_PLACES_API_SECRET=your_os_places_api_secret
# Optional override (defaults to https://api.os.uk/search/places/v1/find)
OS_PLACES_BASE_URL=https://api.os.uk/search/places/v1/find
