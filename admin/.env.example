# ElderConnect+ Admin Dashboard Configuration Example
# Copy this file to .env.local and update with your actual values

# ============================================================================
# SUPABASE CONFIGURATION (Required)
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# API CONFIGURATION
# ============================================================================

NEXT_PUBLIC_API_BASE_URL=http://localhost:54321/rest/v1
NEXT_PUBLIC_API_TIMEOUT=30000

# ============================================================================
# DONATION CONFIGURATION
# ============================================================================
# Web donations are created via Supabase Edge Functions.
# Stripe secret keys should be configured in Supabase Function secrets,
# not in the admin dashboard runtime environment.

NEXT_PUBLIC_DONATIONS_ENABLED=true

# ============================================================================
# AUTHENTICATION
# ============================================================================

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# ============================================================================
# FEATURE FLAGS
# ============================================================================

NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_USER_MANAGEMENT=true
NEXT_PUBLIC_ENABLE_VERIFICATION=true
NEXT_PUBLIC_ENABLE_DONATION_TRACKING=true
NEXT_PUBLIC_ENABLE_REPORTS=true

# ============================================================================
# GOOGLE ANALYTICS (Optional)
# ============================================================================

NEXT_PUBLIC_GA_ID=G-your-google-analytics-id

# ============================================================================
# SENTRY ERROR TRACKING (Optional)
# ============================================================================

NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================================================
# THEMING
# ============================================================================

NEXT_PUBLIC_PRIMARY_COLOR=#6366F1
NEXT_PUBLIC_SECONDARY_COLOR=#10B981
NEXT_PUBLIC_FONT_FAMILY=Poppins

# ============================================================================
# LOGGING & DEBUG
# ============================================================================

LOG_LEVEL=info
DEBUG_MODE=false

# ============================================================================
# EMAIL NOTIFICATIONS
# ============================================================================

SENDGRID_API_KEY=SG.your-sendgrid-key-here
ADMIN_EMAIL=admin@elderconnect.plus

# ============================================================================
# PAGINATION
# ============================================================================

NEXT_PUBLIC_ITEMS_PER_PAGE=20

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Values: development, staging, production

NODE_ENV=development
